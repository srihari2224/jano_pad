# Error monitoring (browser-exposed — must be VITE_-prefixed).
VITE_SENTRY_DSN=https://<key>@<org>.ingest.de.sentry.io/<project>

# Firebase web config (browser-exposed — must be VITE_-prefixed).
# These are NOT secret: access is controlled by Firebase Authorized domains +
# security rules. Copy from Firebase console → Project settings → Your apps.
# Add the same vars in Vercel → Project → Settings → Environment Variables.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=janopad.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=janopad
VITE_FIREBASE_STORAGE_BUCKET=janopad.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Server-side only (NOT VITE_-prefixed, never sent to the browser).
# Used by api/enhance.js for the AI note actions.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: override the AI model if the default is unavailable.
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash
