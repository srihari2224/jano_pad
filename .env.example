# Error monitoring (browser-exposed — must be VITE_-prefixed).
VITE_SENTRY_DSN=https://<key>@<org>.ingest.de.sentry.io/<project>

# Server-side only (NOT VITE_-prefixed, never sent to the browser).
# Used by api/enhance.js for the AI note actions.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: override the AI model if the default is unavailable.
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash
